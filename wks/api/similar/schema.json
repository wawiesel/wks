{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wks/specifications/similar_output.schema.json",
  "title": "WKS Similar Output Schemas",
  "type": "object",
  "definitions": {
    "Base": {
      "type": "object",
      "properties": {
        "errors": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["errors", "warnings"],
      "additionalProperties": true
    },
    "SimilarEvidence": {
      "type": "object",
      "properties": {
        "query_chunk_index": { "type": "integer" },
        "candidate_chunk_index": { "type": "integer" },
        "score": { "type": "number" },
        "query_text": { "type": "string" },
        "candidate_text": { "type": "string" }
      },
      "required": ["query_chunk_index", "candidate_chunk_index", "score", "query_text", "candidate_text"],
      "additionalProperties": false
    },
    "SimilarHit": {
      "type": "object",
      "properties": {
        "uri": { "type": "string" },
        "label": {
          "type": "string",
          "enum": ["exact_duplicate", "near_duplicate", "same_document_family", "topic_related"]
        },
        "score": { "type": "number" },
        "matched_chunks": { "type": "integer" },
        "coverage_query": { "type": "number" },
        "coverage_candidate": { "type": "number" },
        "mean_similarity": { "type": "number" },
        "max_similarity": { "type": "number" },
        "order_consistency": { "type": "number" },
        "stem_similarity": { "type": "number" },
        "path_similarity": { "type": "number" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/definitions/SimilarEvidence" }
        }
      },
      "required": [
        "uri",
        "label",
        "score",
        "matched_chunks",
        "coverage_query",
        "coverage_candidate",
        "mean_similarity",
        "max_similarity",
        "order_consistency",
        "stem_similarity",
        "path_similarity",
        "evidence"
      ],
      "additionalProperties": false
    },
    "SimilarOutput": {
      "allOf": [
        { "$ref": "#/definitions/Base" },
        {
          "type": "object",
          "properties": {
            "query_uri": { "type": "string" },
            "index_name": { "type": "string" },
            "embedding_model": {
              "oneOf": [
                { "type": "string" },
                { "type": "null" }
              ]
            },
            "query_chunk_count": { "type": "integer" },
            "candidate_count": { "type": "integer" },
            "hits": {
              "type": "array",
              "items": { "$ref": "#/definitions/SimilarHit" }
            }
          },
          "required": ["query_uri", "index_name", "embedding_model", "query_chunk_count", "candidate_count", "hits"],
          "additionalProperties": false
        }
      ]
    }
  },
  "oneOf": [
    { "$ref": "#/definitions/SimilarOutput" }
  ]
}
